# 财神爷 v2 — Environment variables (operator-managed)
#
# CRITICAL — Constitution §1, §10, §13:
#   This file is the .example PLACEHOLDER. Copy it to .env.local and fill in
#   real values. NEVER commit .env.local. NEVER add `ANTHROPIC_API_KEY` here
#   or anywhere — it's structurally forbidden (audit-no-api-key.sh + lefthook
#   pre-commit + CI all reject it).
#
# Setup workflow:
#   1. cp .env.example .env.local
#   2. Fill in each value below per the contract's "Setup required" section.
#   3. bash .harness/init.sh   (preflight checks all required values)
#   4. Begin development.

# ─────────────────────────────────────────────────────────────────────────────
# Database — Vercel Postgres (Neon) or self-hosted
# ─────────────────────────────────────────────────────────────────────────────
# Vercel: Marketplace → Postgres → Neon → copy connection string.
# Local: postgresql://postgres:postgres@localhost:5432/caishen (docker-compose.yml)
DATABASE_URL=postgresql://user:password@host:5432/caishen_REPLACE_ME

# ─────────────────────────────────────────────────────────────────────────────
# Tailscale Funnel (FR-009 — VPS → cloud transport)
# ─────────────────────────────────────────────────────────────────────────────
# Tailscale admin console → Settings → Keys → Generate auth key.
# Flags: --ephemeral=false --reusable=false --tags=tag:caishen-vps.
TAILSCALE_AUTH_KEY=tskey-auth-REPLACE_ME

# Tailscale admin → Settings → Funnel → enable for tag:caishen-vps.
# Hostname is `<machine-name>.<your-tailnet>.ts.net`.
TAILSCALE_FUNNEL_HOSTNAME=caishen-vps.your-tailnet.ts.net

# MT5 REST endpoint behind the Tailscale Funnel + nginx bearer proxy.
# Format: https://<TAILSCALE_FUNNEL_HOSTNAME>/mt5
MT5_BASE_URL=https://caishen-vps.your-tailnet.ts.net/mt5

# Bearer token enforced by the nginx proxy in front of MT5 REST. Generate:
#   openssl rand -hex 32
MT5_BEARER_TOKEN=REPLACE_ME_32_BYTES_HEX

# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot (FR-019 — outbound notifications)
# ─────────────────────────────────────────────────────────────────────────────
# Create via @BotFather on Telegram: /newbot → name → username → token.
TELEGRAM_BOT_TOKEN=123456789:REPLACE_ME_35_CHARS

# Your own Telegram user ID (DM @userinfobot to get it). JSON array of ints.
ALLOWED_TELEGRAM_USER_IDS=[123456789]

# Optional debug-channel ID for the synthetic-ping fallback (FR-005 R5).
# Create a private channel, add the bot as admin, capture chat ID via
# https://api.telegram.org/bot<TOKEN>/getUpdates after sending a message.
TELEGRAM_DEBUG_CHANNEL_ID=-1001234567890

# ─────────────────────────────────────────────────────────────────────────────
# Vercel — Blob, Cron, deployment
# ─────────────────────────────────────────────────────────────────────────────
# Vercel: Marketplace → Blob → install → copy token.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_REPLACE_ME

# High-entropy random for Vercel cron auth. Generate: openssl rand -hex 32
CRON_SECRET=REPLACE_ME_32_BYTES_HEX

# Optional — only needed if CI deploys via Vercel CLI.
VERCEL_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic Routines (per ADR-004 — bearer-token-per-routine, NOT API key)
# ─────────────────────────────────────────────────────────────────────────────
# Pinned beta header (ADR-004). Bumped manually when Anthropic releases a new
# routine API version. CI's beta-header smoke test runs Spike 3 and pages on
# unexpected version drift.
ROUTINE_BETA_HEADER=experimental-cc-routine-2026-04-01

# Filled in MID-BUILD after Generator creates each routine in the Anthropic
# console. Format below is per the contract's API surface section.
PLANNER_ROUTINE_ID=
PLANNER_ROUTINE_BEARER=
EXECUTOR_ROUTINE_IDS={}
EXECUTOR_ROUTINE_BEARERS={}

# ─────────────────────────────────────────────────────────────────────────────
# Auth.js (dashboard authentication + R6 CSRF HMAC)
# ─────────────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET=REPLACE_ME_32_BYTES_HEX

# One-time, high-entropy. Generate: openssl rand -hex 32
INITIAL_REGISTRATION_TOKEN=REPLACE_ME_32_BYTES_HEX

# Vercel preview URL once first deploy completes.
AUTH_URL=https://caishen-dashboard.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# ForexFactory MCP (FR-002 — news fetch)
# ─────────────────────────────────────────────────────────────────────────────
# Existing connector — reuse credentials from the n8n workflow.
FFCAL_BASE_URL=
FFCAL_BEARER_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Audit retention (per ADR-006)
# ─────────────────────────────────────────────────────────────────────────────
# Days of hot retention in Postgres before audit-archive cron moves rows to
# Vercel Blob cold archive. Default 365.
AUDIT_HOT_DAYS=365

# ─────────────────────────────────────────────────────────────────────────────
# Tenant defaults (FR-008 — multi-tenant from day one)
# ─────────────────────────────────────────────────────────────────────────────
# v1 ships single-tenant; tenant_id always = 1.
DEFAULT_TENANT_ID=1

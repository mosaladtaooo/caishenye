{
  "name": "@caishen/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/override-actions": "./src/schema/override-actions.ts",
    "./schema/agent-state": "./src/schema/agent-state.ts",
    "./schema/users": "./src/schema/users.ts",
    "./schema/tenants": "./src/schema/tenants.ts",
    "./schema/pair-schedules": "./src/schema/pair-schedules.ts",
    "./schema/routine-runs": "./src/schema/routine-runs.ts",
    "./schema/telegram-interactions": "./src/schema/telegram-interactions.ts",
    "./schema/orders": "./src/schema/orders.ts",
    "./schema/executor-reports": "./src/schema/executor-reports.ts",
    "./schema/cap-usage": "./src/schema/cap-usage.ts",
    "./client": "./src/client.ts",
    "./audit": "./src/audit.ts",
    "./queries/pairs": "./src/queries/pairs.ts",
    "./lint/tenant-id": "./src/lint/tenant-id-lint.ts"
  },
  "scripts": {
    "tsc": "tsc --noEmit -p tsconfig.json",
    "test": "vitest",
    "test:run": "vitest run",
    "migrate": "bun run src/migrate.ts",
    "lint:tenant-id": "bun run src/lint/tenant-id-lint.ts",
    "seed": "bun run src/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "0.39.1",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "@types/node": "20.19.0",
    "drizzle-kit": "0.30.2",
    "vitest": "3.2.4"
  }
}
